# ─── Auth ──────────────────────────────────────────────
# Password required to access the approval dashboard.
# Pick a long, random string for production.
APPROVAL_PASSWORD=change-me-please

# 32+ character secret used to sign the iron-session cookie.
# Generate with: openssl rand -hex 32 (or node -e "console.log(crypto.randomBytes(32).toString('hex'))")
SESSION_SECRET=replace-with-a-32+-char-random-string-now

# ─── Storage (Vercel KV / Upstash Redis) ───────────────
# Leave unset to use the in-memory dev store (data resets on restart).
# Provision at: https://vercel.com/<org>/<project>/stores
# Vercel KV auto-injects these when linked to the project.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_USEast=